const GlassPanel = ({ children, className = '', mode, ...props }) => {
  const baseStyle = "backdrop-blur-xl border rounded-3xl shadow-2xl transition-all duration-500";
  const modeStyle = mode === 'kids' 
    ? "bg-white/60 border-white/80 shadow-[0_8px_32px_0_rgba(31,38,135,0.1)] text-slate-800" 
    : "bg-[#0C1B33]/60 border-white/10 shadow-[0_8px_32px_0_rgba(0,0,0,0.5)] text-slate-100";
  
  return (
    <div className={`${baseStyle} ${modeStyle} ${className}`} {...props}>
      {children}
    </div>
  );
};

const Button = ({ onClick, children, variant = 'primary', mode, className = '', disabled = false }) => {
  const base = "relative overflow-hidden rounded-2xl font-bold transition-all duration-200 active:scale-95 flex items-center justify-center gap-2 px-6 py-3";
  
  let colors = "";
  if (mode === 'kids') {
    colors = variant === 'primary' 
      ? "bg-gradient-to-r from-[#00FFCC] to-[#00E5B8] text-teal-900 shadow-lg shadow-teal-500/30 hover:shadow-teal-500/50"
      : "bg-white text-slate-700 shadow-md hover:bg-slate-50";
  } else {
    colors = variant === 'primary'
      ? "bg-gradient-to-r from-[#CD7F32] to-[#B87333] text-white shadow-lg shadow-[#CD7F32]/30 hover:shadow-[#CD7F32]/50 border border-[#CD7F32]/50"
      : "bg-white/10 text-white hover:bg-white/20 border border-white/10";
  }

  if (disabled) colors = "bg-gray-400/50 text-gray-500 cursor-not-allowed opacity-50";

  return (
    <button onClick={onClick} disabled={disabled} className={`${base} ${colors} ${className}`}>
      {children}
    </button>
  );
};

