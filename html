const StroopTest = ({ onFinish, config }) => {
  const WORDS = ["ROJO", "AZUL", "VERDE", "AMARILLO"];
  const COLORS = ["text-red-500", "text-blue-500", "text-green-500", "text-yellow-500"];
  
  const [currentRound, setCurrentRound] = useState(0);
  const [gameState, setGameState] = useState('waiting');
  const [currentWord, setCurrentWord] = useState('');
  const [currentColorClass, setCurrentColorClass] = useState('');
  
  const [metrics, setMetrics] = useState({ aciertos: 0, errores: 0, omisiones: 0, tiempos: [] });
  const showTimeRef = useRef(0);
  const timeoutRef = useRef(null);

  const targetRounds = config.duration === 'mini' ? 5 : 12;
  const timeLimit = config.speed === 'slow' ? 2000 : config.speed === 'fast' ? 1000 : 1500;

  const nextRound = useCallback(() => {
    if (currentRound >= targetRounds) {
      const avgTime = metrics.tiempos.length > 0 ? (metrics.tiempos.reduce((a,b)=>a+b,0) / metrics.tiempos.length).toFixed(0) : 0;
      onFinish({ ...metrics, tiempoMedio: avgTime + "ms", rondas: targetRounds });
      return;
    }
    setGameState('showing');
    const isTarget = Math.random() < 0.4; 
    let wordText = isTarget ? "AZUL" : WORDS[Math.floor(Math.random() * WORDS.length)];
    setCurrentWord(wordText);
    setCurrentColorClass(COLORS[Math.floor(Math.random() * COLORS.length)]);
    setCurrentRound(r => r + 1);
    showTimeRef.current = Date.now();

    timeoutRef.current = setTimeout(() => {
      if (wordText === "AZUL") setMetrics(m => ({ ...m, omisiones: m.omisiones + 1 }));
      nextRound();
    }, timeLimit);
  }, [currentRound, metrics, onFinish, targetRounds, timeLimit]);

  useEffect(() => {
    const t = setTimeout(nextRound, 1000);
    return () => clearTimeout(t);
  }, []);

  const handleReaction = () => {
    if (gameState !== 'showing') return;
    clearTimeout(timeoutRef.current);
    const reactionTime = Date.now() - showTimeRef.current;
    
    if (currentWord === "AZUL") {
      setMetrics(m => ({ ...m, aciertos: m.aciertos + 1, tiempos: [...m.tiempos, reactionTime] }));
    } else {
      setMetrics(m => ({ ...m, errores: m.errores + 1 }));
    }
    setGameState('waiting');
    setTimeout(nextRound, 500);
  };

  useEffect(() => {
    const handleKeyDown = (e) => { if (e.code === 'Space') { e.preventDefault(); handleReaction(); } };
    window.addEventListener('keydown', handleKeyDown);
    return () => window.removeEventListener('keydown', handleKeyDown);
  }, [handleReaction]);

  return (
    <div className="flex flex-col items-center justify-center py-12 gap-8 text-center">
      <div className="space-y-2">
        <h3 className="text-xl text-slate-400 font-light">Inhibición y Reacción</h3>
        <p className="text-sm text-slate-500">Presiona Reaccionar <strong className="text-white">SOLO</strong> cuando leas "AZUL".</p>
      </div>
      <div className="h-32 flex items-center justify-center">
        {gameState === 'showing' ? (
          <h1 className={`text-6xl font-black tracking-widest uppercase drop-shadow-[0_0_15px_rgba(255,255,255,0.2)] ${currentColorClass}`}>{currentWord}</h1>
        ) : <div className="text-slate-600 text-2xl font-light animate-pulse">+</div>}
      </div>
      <Button onClick={handleReaction} mode="adults" className="w-64 py-6 text-xl tracking-wider">REACCIONAR</Button>
      <div className="text-slate-500 text-sm">Ronda {currentRound}/{targetRounds}</div>
    </div>
  );
};

const AdvancedMemory = ({ onFinish, config }) => {
  const [level, setLevel] = useState(config.speed === 'fast' ? 4 : 3); 
  const [sequence, setSequence] = useState([]);
  const [displayNumber, setDisplayNumber] = useState(null);
  const [phase, setPhase] = useState('start');
  const [userInput, setUserInput] = useState('');
  const [roundsPlayed, setRoundsPlayed] = useState(0);

  const targetRounds = config.duration === 'mini' ? 3 : 5;
  const showTime = config.speed === 'slow' ? 1500 : config.speed === 'fast' ? 600 : 1000;

  const generateSequence = useCallback(() => {
    const seq = Array.from({length: level}, () => Math.floor(Math.random() * 10));
    setSequence(seq);
    return seq;
  }, [level]);

  const startLevel = useCallback(() => {
    const seq = generateSequence();
    setPhase('showing');
    setUserInput('');
    let step = 0;
    const interval = setInterval(() => {
      if (step >= seq.length) {
        clearInterval(interval);
        setDisplayNumber(null);
        setPhase('input');
        return;
      }
      setDisplayNumber(seq[step]);
      step++;
    }, showTime);
  }, [generateSequence, showTime]);

  const handleInput = (num) => {
    if (phase !== 'input') return;
    const newVal = userInput + num.toString();
    setUserInput(newVal);

    if (newVal.length === sequence.length) {
      if (roundsPlayed + 1 >= targetRounds) {
        setTimeout(() => onFinish({ nivelFinal: level, estado: newVal === sequence.join('') ? 'Éxito final' : 'Fallo final' }), 1000);
      } else {
        if (newVal === sequence.join('')) {
          setTimeout(() => { setLevel(l => l + 1); setRoundsPlayed(r=>r+1); setPhase('start'); }, 1000);
        } else {
          setTimeout(() => onFinish({ nivelFinal: level, estado: 'Cometió error' }), 1000);
        }
      }
    }
  };

  useEffect(() => {
    if (phase === 'start') {
      const t = setTimeout(startLevel, 1000);
      return () => clearTimeout(t);
    }
  }, [phase, startLevel]);

  return (
    <div className="flex flex-col items-center gap-8 py-8 text-center">
      <div className="space-y-2">
        <h3 className="text-xl text-slate-400 font-light">Memoria Numérica (Ronda {roundsPlayed + 1}/{targetRounds})</h3>
        <p className="text-sm text-slate-500">Memoriza la secuencia.</p>
      </div>
      <div className="h-32 flex items-center justify-center">
        {phase === 'showing' && displayNumber !== null && (
          <h1 className="text-8xl font-light text-white drop-shadow-[0_0_20px_rgba(205,127,50,0.5)]">{displayNumber}</h1>
        )}
        {phase === 'input' && (
          <div className="text-4xl tracking-[1em] text-[#CD7F32] font-mono">{userInput.padEnd(sequence.length, '_')}</div>
        )}
      </div>
      <div className={`grid grid-cols-3 gap-4 transition-opacity duration-500 ${phase === 'input' ? 'opacity-100' : 'opacity-0 pointer-events-none'}`}>
        {[1,2,3,4,5,6,7,8,9].map(num => (
          <button key={num} onClick={() => handleInput(num)} className="w-16 h-16 rounded-full bg-white/5 border border-white/10 text-xl font-light hover:bg-white/20 active:bg-[#CD7F32] transition-colors">{num}</button>
        ))}
        <div />
        <button onClick={() => handleInput(0)} className="w-16 h-16 rounded-full bg-white/5 border border-white/10 text-xl font-light hover:bg-white/20 active:bg-[#CD7F32] transition-colors">0</button>
      </div>
    </div>
  );
};

const NumberSequence = ({ onFinish, config }) => {
  const [sequence, setSequence] = useState([]);
  const [options, setOptions] = useState([]);
  const [missingIndex, setMissingIndex] = useState(0);
  const [round, setRound] = useState(1);
  const [score, setScore] = useState(0);

  const targetRounds = config.duration === 'mini' ? 4 : 8;

  const generateSequence = useCallback(() => {
    const diff = config.speed === 'fast' ? Math.floor(Math.random() * 10) + 5 : Math.floor(Math.random() * 5) + 2;
    const start = Math.floor(Math.random() * 20);
    const seq = Array.from({length: 5}, (_, i) => start + (i * diff));
    const mIndex = Math.floor(Math.random() * 5);
    const correctAns = seq[mIndex];
    
    let opts = [correctAns];
    while(opts.length < 4) {
      let falseOpt = correctAns + (Math.floor(Math.random() * 10) - 5) * diff;
      if (falseOpt !== correctAns && !opts.includes(falseOpt) && falseOpt > 0) opts.push(falseOpt);
    }
    
    setSequence(seq);
    setMissingIndex(mIndex);
    setOptions(opts.sort(() => Math.random() - 0.5));
  }, [config.speed]);

  useEffect(() => { generateSequence(); }, [generateSequence]);

  const handleSelect = (num) => {
    if (num === sequence[missingIndex]) setScore(s => s + 1);
    
    if (round >= targetRounds) {
      onFinish({ aciertos: score + (num === sequence[missingIndex] ? 1 : 0), rondas: targetRounds });
    } else {
      setRound(r => r + 1);
      generateSequence();
    }
  };

  return (
    <div className="flex flex-col items-center gap-8 py-8 text-center">
      <div className="space-y-2">
        <h3 className="text-xl text-slate-400 font-light">Razonamiento (Ronda {round}/{targetRounds})</h3>
        <p className="text-sm text-slate-500">¿Qué número falta en la secuencia?</p>
      </div>
      <div className="flex gap-4 text-3xl font-mono text-white bg-white/5 p-6 rounded-2xl border border-white/10">
        {sequence.map((num, i) => (
          <span key={i} className={i === missingIndex ? "text-[#CD7F32] animate-pulse" : ""}>
            {i === missingIndex ? "??" : num}
          </span>
        ))}
      </div>
      <div className="grid grid-cols-2 gap-4 w-full max-w-xs">
        {options.map((opt, i) => (
          <Button key={i} onClick={() => handleSelect(opt)} variant="secondary" mode="adults" className="text-2xl font-mono py-4">
            {opt}
          </Button>
        ))}
      </div>
    </div>
  );
};

const VisualStimulus = ({ onFinish, config }) => {
  const symbols = ['▲', '■', '●', '◆', '★', '✚', '✿', '✺'];
  const [phase, setPhase] = useState('ready'); // ready, showing, options
  const [targetSymbol, setTargetSymbol] = useState('');
  const [options, setOptions] = useState([]);
  const [round, setRound] = useState(1);
  const [score, setScore] = useState(0);

  const targetRounds = config.duration === 'mini' ? 4 : 8;
  const showTime = config.speed === 'slow' ? 800 : config.speed === 'fast' ? 200 : 500;

  const startRound = useCallback(() => {
    setPhase('ready');
    const target = symbols[Math.floor(Math.random() * symbols.length)];
    setTargetSymbol(target);
    
    let opts = [target];
    while(opts.length < 4) {
      let rand = symbols[Math.floor(Math.random() * symbols.length)];
      if (!opts.includes(rand)) opts.push(rand);
    }
    setOptions(opts.sort(() => Math.random() - 0.5));

    setTimeout(() => {
      setPhase('showing');
      setTimeout(() => {
        setPhase('options');
      }, showTime);
    }, 1000);
  }, [showTime]);

  useEffect(() => { startRound(); }, [startRound]);

  const handleSelect = (sym) => {
    if (sym === targetSymbol) setScore(s => s + 1);
    
    if (round >= targetRounds) {
      onFinish({ aciertos: score + (sym === targetSymbol ? 1 : 0), rondas: targetRounds });
    } else {
      setRound(r => r + 1);
      startRound();
    }
  };

  return (
    <div className="flex flex-col items-center gap-8 py-8 text-center min-h-[300px]">
      <div className="space-y-2">
        <h3 className="text-xl text-slate-400 font-light">Estímulo Visual (Ronda {round}/{targetRounds})</h3>
        <p className="text-sm text-slate-500">
          {phase === 'options' ? "¿Qué símbolo apareció?" : "Prepárate..."}
        </p>
      </div>
      
      <div className="h-40 flex items-center justify-center">
        {phase === 'ready' && <div className="text-white text-3xl font-light">3, 2, 1...</div>}
        {phase === 'showing' && <div className="text-8xl text-white drop-shadow-[0_0_15px_rgba(255,255,255,0.5)]">{targetSymbol}</div>}
        {phase === 'options' && (
          <div className="grid grid-cols-2 gap-4">
            {options.map((opt, i) => (
              <button key={i} onClick={() => handleSelect(opt)} className="w-20 h-20 text-4xl text-white bg-white/5 border border-white/10 rounded-2xl hover:bg-white/20 transition-all">
                {opt}
              </button>
            ))}
          </div>
        )}
      </div>
    </div>
  );
};


