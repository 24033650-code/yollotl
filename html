const CatchTheStar = ({ onFinish, config }) => {
  const [score, setScore] = useState(0);
  const [lives, setLives] = useState(3);
  const [starPos, setStarPos] = useState({ x: 50, y: 0 });
  const [playerX, setPlayerX] = useState(50);
  const [isPlaying, setIsPlaying] = useState(true);
  const containerRef = useRef(null);
  const requestRef = useRef();

  const targetScore = config.duration === 'mini' ? 5 : 10;
  const speedMultiplier = config.speed === 'slow' ? 0.5 : config.speed === 'fast' ? 1.5 : 1;

  const handleMove = (e) => {
    if (!containerRef.current || !isPlaying) return;
    const rect = containerRef.current.getBoundingClientRect();
    let clientX = e.clientX;
    if (e.touches && e.touches.length > 0) clientX = e.touches[0].clientX;
    let x = ((clientX - rect.left) / rect.width) * 100;
    setPlayerX(Math.max(5, Math.min(95, x)));
  };

  useEffect(() => {
    if (!isPlaying) return;
    let speed = (0.5 + (score * 0.05)) * speedMultiplier;
    let currentY = starPos.y;

    const update = () => {
      currentY += speed;
      if (currentY > 85 && currentY < 95) {
        if (Math.abs(starPos.x - playerX) < 15) {
          setScore(s => s + 1);
          setStarPos({ x: Math.random() * 80 + 10, y: 0 });
          currentY = 0;
          if (score + 1 >= targetScore) {
            setIsPlaying(false);
            setTimeout(() => onFinish({ score: targetScore, status: 'Victoria' }), 1000);
          }
        }
      } else if (currentY > 100) {
        setLives(l => {
          const newLives = l - 1;
          if (newLives <= 0) {
            setIsPlaying(false);
            setTimeout(() => onFinish({ score, status: 'Derrota' }), 1000);
          }
          return newLives;
        });
        setStarPos({ x: Math.random() * 80 + 10, y: 0 });
        currentY = 0;
      } else {
        setStarPos(prev => ({ ...prev, y: currentY }));
      }
      requestRef.current = requestAnimationFrame(update);
    };
    requestRef.current = requestAnimationFrame(update);
    return () => cancelAnimationFrame(requestRef.current);
  }, [isPlaying, starPos.x, playerX, score, onFinish, targetScore, speedMultiplier]);

  return (
    <div className="w-full h-[60vh] relative overflow-hidden bg-gradient-to-b from-blue-900 to-indigo-900 rounded-3xl cursor-none touch-none" ref={containerRef} onMouseMove={handleMove} onTouchMove={handleMove}>
      <div className="absolute top-4 left-4 right-4 flex justify-between text-white font-bold text-xl z-10">
        <div className="flex items-center gap-2"><Star className="text-yellow-400 fill-yellow-400" /> {score}/{targetScore}</div>
        <div className="flex items-center gap-2 text-red-400">{'❤️'.repeat(lives)}</div>
      </div>
      <div className="absolute w-8 h-8 text-yellow-300 transition-transform duration-75" style={{ left: `${starPos.x}%`, top: `${starPos.y}%`, transform: 'translate(-50%, -50%)', filter: 'drop-shadow(0 0 10px rgba(255,215,0,0.8))' }}>
        <Star className="w-full h-full fill-current animate-spin-slow" />
      </div>
      <div className="absolute bottom-4 w-24 h-6 bg-[#00FFCC] rounded-full shadow-[0_0_20px_#00FFCC] transition-transform duration-75" style={{ left: `${playerX}%`, transform: 'translateX(-50%)' }} />
    </div>
  );
};

const ColorMemory = ({ onFinish, config }) => {
  const colors = [
    { id: 0, bg: 'bg-red-400', active: 'bg-red-300 shadow-[0_0_30px_#f87171]' },
    { id: 1, bg: 'bg-blue-400', active: 'bg-blue-300 shadow-[0_0_30px_#60a5fa]' },
    { id: 2, bg: 'bg-green-400', active: 'bg-green-300 shadow-[0_0_30px_#4ade80]' },
    { id: 3, bg: 'bg-yellow-400', active: 'bg-yellow-300 shadow-[0_0_30px_#facc15]' }
  ];

  const [sequence, setSequence] = useState([]);
  const [playerStep, setPlayerStep] = useState(0);
  const [isShowing, setIsShowing] = useState(false);
  const [activeIndex, setActiveIndex] = useState(null);
  const [level, setLevel] = useState(1);

  const targetLevel = config.duration === 'mini' ? 4 : 8;
  const showTime = config.speed === 'slow' ? 1000 : config.speed === 'fast' ? 500 : 800;

  const addNewColor = useCallback(() => setSequence(prev => [...prev, Math.floor(Math.random() * 4)]), []);

  useEffect(() => { addNewColor(); }, [addNewColor]);

  useEffect(() => {
    if (sequence.length === 0) return;
    let step = 0;
    setIsShowing(true);
    const interval = setInterval(() => {
      if (step >= sequence.length) {
        clearInterval(interval);
        setActiveIndex(null);
        setIsShowing(false);
        return;
      }
      setActiveIndex(sequence[step]);
      setTimeout(() => setActiveIndex(null), showTime / 2);
      step++;
    }, showTime);
    return () => clearInterval(interval);
  }, [sequence, showTime]);

  const handleColorClick = (id) => {
    if (isShowing) return;
    setActiveIndex(id);
    setTimeout(() => setActiveIndex(null), 200);

    if (id === sequence[playerStep]) {
      if (playerStep === sequence.length - 1) {
        if (level >= targetLevel) {
          setTimeout(() => onFinish({ nivel: level, estado: 'Completado' }), 1000);
        } else {
          setTimeout(() => {
            setLevel(l => l + 1);
            setPlayerStep(0);
            addNewColor();
          }, 1000);
        }
      } else {
        setPlayerStep(p => p + 1);
      }
    } else {
      onFinish({ nivel: level, estado: 'Falló secuencia' });
    }
  };

  return (
    <div className="flex flex-col items-center gap-8 py-8">
      <h3 className="text-2xl font-bold text-slate-700">Nivel {level} / {targetLevel}</h3>
      <div className="grid grid-cols-2 gap-4 w-64 h-64">
        {colors.map((c) => (
          <button key={c.id} onClick={() => handleColorClick(c.id)} disabled={isShowing}
            className={`rounded-3xl transition-all duration-200 ${c.bg} ${activeIndex === c.id ? c.active + ' scale-105' : 'scale-100 opacity-80'} ${isShowing ? 'cursor-default' : 'cursor-pointer hover:opacity-100'}`} />
        ))}
      </div>
      <p className="text-slate-500 font-medium h-6">{isShowing ? "Observa la secuencia..." : "¡Tu turno!"}</p>
    </div>
  );
};

const CountAndLearn = ({ onFinish, config }) => {
  const [targetCount, setTargetCount] = useState(0);
  const [options, setOptions] = useState([]);
  const [round, setRound] = useState(1);
  const [score, setScore] = useState(0);
  const targetRounds = config.duration === 'mini' ? 3 : 6;
  
  const emojis = ['🍎', '🐶', '🚗', '🎈', '⭐'];
  const [activeEmoji, setActiveEmoji] = useState('🍎');

  const generateRound = useCallback(() => {
    const maxCount = config.speed === 'fast' ? 12 : config.speed === 'slow' ? 5 : 8;
    const count = Math.floor(Math.random() * maxCount) + 1;
    setTargetCount(count);
    setActiveEmoji(emojis[Math.floor(Math.random() * emojis.length)]);
    
    let opts = [count];
    while(opts.length < 3) {
      let randomOpt = Math.floor(Math.random() * maxCount) + 1;
      if (!opts.includes(randomOpt)) opts.push(randomOpt);
    }
    setOptions(opts.sort(() => Math.random() - 0.5));
  }, [config.speed]);

  useEffect(() => { generateRound(); }, [generateRound]);

  const handleSelect = (num) => {
    if (num === targetCount) setScore(s => s + 1);
    if (round >= targetRounds) {
      onFinish({ aciertos: score + (num === targetCount ? 1 : 0), rondas: targetRounds });
    } else {
      setRound(r => r + 1);
      generateRound();
    }
  };

  return (
    <div className="flex flex-col items-center gap-6 py-6 text-center">
      <h3 className="text-xl font-bold text-slate-700">Ronda {round}/{targetRounds}</h3>
      <p className="text-slate-600">¿Cuántos objetos hay?</p>
      <div className="flex flex-wrap justify-center gap-4 w-64 min-h-[120px] bg-white/50 p-4 rounded-2xl">
        {Array.from({ length: targetCount }).map((_, i) => (
          <span key={i} className="text-4xl animate-bounce" style={{ animationDelay: `${i * 0.1}s` }}>{activeEmoji}</span>
        ))}
      </div>
      <div className="flex gap-4 mt-4">
        {options.map(opt => (
          <button key={opt} onClick={() => handleSelect(opt)} className="w-16 h-16 bg-white rounded-2xl shadow-md text-3xl font-bold text-teal-600 hover:bg-teal-50 hover:scale-105 transition-all">
            {opt}
          </button>
        ))}
      </div>
    </div>
  );
};

const FindTheAnimal = ({ onFinish, config }) => {
  const animals = ['🐶', '🐱', '🐭', '🐹', '🐰', '🦊', '🐻', '🐼', '🐨', '🐯', '🦁', '🐮'];
  const [targetAnimal, setTargetAnimal] = useState('');
  const [grid, setGrid] = useState([]);
  const [round, setRound] = useState(1);
  const [score, setScore] = useState(0);
  const targetRounds = config.duration === 'mini' ? 3 : 6;
  const gridSize = config.speed === 'fast' ? 16 : config.speed === 'slow' ? 6 : 9;

  const generateRound = useCallback(() => {
    const target = animals[Math.floor(Math.random() * animals.length)];
    setTargetAnimal(target);
    let newGrid = [target];
    while(newGrid.length < gridSize) {
      let randomAnimal = animals[Math.floor(Math.random() * animals.length)];
      if (randomAnimal !== target) newGrid.push(randomAnimal);
    }
    setGrid(newGrid.sort(() => Math.random() - 0.5));
  }, [gridSize]);

  useEffect(() => { generateRound(); }, [generateRound]);

  const handleSelect = (animal) => {
    if (animal === targetAnimal) setScore(s => s + 1);
    if (round >= targetRounds) {
      onFinish({ aciertos: score + (animal === targetAnimal ? 1 : 0), rondas: targetRounds });
    } else {
      setRound(r => r + 1);
      generateRound();
    }
  };

  return (
    <div className="flex flex-col items-center gap-6 py-6 text-center">
      <h3 className="text-xl font-bold text-slate-700">Ronda {round}/{targetRounds}</h3>
      <p className="text-slate-600 flex items-center gap-2">Encuentra a: <span className="text-4xl bg-white/50 p-2 rounded-xl">{targetAnimal}</span></p>
      <div className={`grid gap-3 ${gridSize > 9 ? 'grid-cols-4' : 'grid-cols-3'}`}>
        {grid.map((animal, i) => (
          <button key={i} onClick={() => handleSelect(animal)} className="w-16 h-16 bg-white rounded-2xl shadow-md text-4xl flex items-center justify-center hover:bg-teal-50 hover:scale-105 transition-all">
            {animal}
          </button>
        ))}
      </div>
    </div>
  );
};

